import re

def validate_credit_card(card):
    # 1. Check basic structure: 
    # Starts with 4, 5, or 6.
    # Exactly 16 digits total.
    # Allowed formats: 16 digits straight OR 4 groups of 4 separated by '-'
    structure_pattern = r"^[456](?:\d{15}|\d{3}(?:-\d{4}){3})$"
    
    if not re.match(structure_pattern, card):
        return "Invalid"
    
    # 2. Check for consecutive repeated digits
    # First, remove hyphens to check the underlying sequence of 16 digits
    clean_card = card.replace("-", "")
    
    # regex for 4 or more consecutive identical characters
    if re.search(r"(\d)\1{3,}", clean_card):
        return "Invalid"
    
    return "Valid"

# Read number of test cases
for _ in range(int(input())):
    print(validate_credit_card(input().strip()))
