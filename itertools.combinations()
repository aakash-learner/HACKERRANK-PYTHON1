from itertools import combinations

# Read string s and integer k
s, k = input().split()
k = int(k)

# Sort the string to ensure combinations are produced in alphabetical order
s_sorted = sorted(s)

# Iterate through each size i from 1 to k
for i in range(1, k + 1):
    # Generate combinations of length i
    for combo in combinations(s_sorted, i):
        # Join the tuple into a string and print
        print("".join(combo))
