# Read input for Set M
m_size = int(input())
m_set = set(map(int, input().split()))

# Read input for Set N
n_size = int(input())
n_set = set(map(int, input().split()))

# Calculate Symmetric Difference
# This finds elements in (M - N) and (N - M)
sym_diff = m_set.symmetric_difference(n_set)

# Sort the resulting set and print each element
for element in sorted(sym_diff):
    print(element)
