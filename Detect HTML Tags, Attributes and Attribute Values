from html.parser import HTMLParser
import sys

class MyHTMLParser(HTMLParser):
    def handle_starttag(self, tag, attrs):
        # First, print the tag name
        print(tag)
        # Then, print each attribute and value on its own line
        for attr, value in attrs:
            print(f"-> {attr} > {value}")

# Read number of lines
try:
    line_count = int(sys.stdin.readline())
    # Join all lines to handle multi-line tags and comments
    html_content = "".join([sys.stdin.readline() for _ in range(line_count)])
    
    parser = MyHTMLParser()
    parser.feed(html_content)
    parser.close()
except (EOFError, ValueError):
    pass
