import re

def validate_uid(uid):
    # Rule 5: Exactly 10 characters, Rule 3: Alphanumeric
    if not re.match(r'^[a-zA-Z0-9]{10}$', uid):
        return "Invalid"
    # Rule 1: At least 2 uppercase letters
    if len(re.findall(r'[A-Z]', uid)) < 2:
        return "Invalid"
    # Rule 2: At least 3 digits
    if len(re.findall(r'\d', uid)) < 3:
        return "Invalid"
    # Rule 4: No character repeats (using a set to compare length)
    if len(set(uid)) != 10:
        return "Invalid"
    return "Valid"

# Input handling
import sys
input_data = sys.stdin.read().split()
t = int(input_data[0])
for i in range(1, t + 1):
    print(validate_uid(input_data[i]))
